# Copy to .env and fill values when integrating APIs
BROKER=paper
SYMBOL=XAUUSD
TIMEFRAME=15m
RISK_PER_TRADE=0.01
INITIAL_BALANCE=10000

# Data source for backtest: yfinance | mock
DATA_PROVIDER=yfinance
YFINANCE_SYMBOL=GC=F
YFINANCE_PERIOD=60d

# Risk settings
STOP_LOSS_PCT=0.01
TAKE_PROFIT_PCT=0.02
MAX_POSITION_NOTIONAL_PCT=1.0

# Paper trading loop settings
PAPER_POLL_SECONDS=60
PAPER_MAX_LOOPS=30
